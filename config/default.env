: "${OPENCLAW_SCHEDULER_HOME:=$HOME/.openclaw-power-scheduler}"
: "${OPENCLAW_STATE_ROOT:=$HOME/.openclaw}"
: "${LAUNCH_AGENTS_DIR:=$HOME/Library/LaunchAgents}"

: "${SCHEDULER_START_LABEL:=com.openclaw.scheduler.gateway.start}"
: "${SCHEDULER_STOP_LABEL:=com.openclaw.scheduler.gateway.stop}"
: "${SCHEDULER_WATCHDOG_LABEL:=ai.openclaw.scheduler.watchdog}"
: "${SCHEDULER_KEEPAWAKE_LABEL:=ai.openclaw.scheduler.keepawake}"

: "${OPENCLAW_GATEWAY_PORT:=18801}"

: "${START_HOUR:=8}"
: "${START_MINUTE:=30}"
: "${STOP_HOUR:=0}"
: "${STOP_MINUTE:=0}"

: "${KEEP_AWAKE_START_HOUR:=8}"
: "${KEEP_AWAKE_END_HOUR:=24}"

: "${WATCHDOG_INTERVAL:=120}"
: "${WATCHDOG_COOLDOWN_SECONDS:=180}"

: "${SCHEDULER_SKIP_LAUNCHD:=0}"
